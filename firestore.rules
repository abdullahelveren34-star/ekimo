/**
 * Core Philosophy:
 * This ruleset now operates on a simple "signed-in users can do anything" model.
 * This is a temporary, less secure configuration designed to unblock development and testing
 * of application features without running into permission errors.
 *
 * WARNING: This is not suitable for production. Before going live, these rules MUST be
 * replaced with a more robust, entity-specific ruleset that enforces proper ownership
 * and access control (e.g., only an employee can edit their own profile).
 *
 * Key Security Decisions (for Development):
 * - All collections are readable, writable, and listable by any authenticated user.
 * - This removes the complexity of ownership checks (isOwner, isDocumentOwner) for now,
 *   allowing the frontend to be built and tested freely.
 * - The primary security layer is simply checking if a user is signed in.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // Helper Functions
    // -----------------------------------------------------------------

    /**
     * Checks if a user is authenticated. This is now the primary check.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    // -----------------------------------------------------------------
    // Generic Rule for All Collections
    // -----------------------------------------------------------------
    
    /**
      * @description Allows any signed-in user to perform any action on any document.
      * @path /{document=**}
      * @allow Any authenticated user can read, write, create, and delete any document.
      * @principle Development-first approach to unblock UI/feature development.
      */
    match /{document=**} {
      allow read, write, list: if isSignedIn();
    }
  }
}
